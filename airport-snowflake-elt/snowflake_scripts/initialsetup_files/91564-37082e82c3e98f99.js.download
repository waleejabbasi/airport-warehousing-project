WITH OBJECT_IDS AS (
        SELECT PARSE_JSON(SYSTEM$GET_OBJECT_IDS_FOR_AI_EVAL(?, ?, ?, ?, ?)) AS IDS
),
EVAL_ROOT_SPANS AS (
    SELECT
        *
    FROM
        TABLE(snowflake.local.GET_AI_OBSERVABILITY_EVENTS(?, ?, ?, ?))
    JOIN OBJECT_IDS ON TRUE
    WHERE
        RECORD_ATTRIBUTES:"${l.ae.SPAN_TYPE}" = '${l.du.EVAL_ROOT}' AND
        RECORD_ATTRIBUTES:"${l.ae.RUN_ID}" = OBJECT_IDS.IDS:run.id AND
        RECORD_ATTRIBUTES:"${l.ae.EVAL_TARGET_RECORD_ID}" = (?)
),
EVAL_SPANS AS (
    SELECT
        RECORD_ATTRIBUTES:"${l.ae.EVAL_EVAL_ROOT_ID}" AS ROOT_ID,
        ARRAY_AGG(
            OBJECT_CONSTRUCT(
                'criteria', TO_VARCHAR(RECORD_ATTRIBUTES:"${l.ae.EVAL_CRITERIA}"),
                'explanation', TO_VARCHAR(RECORD_ATTRIBUTES:"${l.ae.EVAL_EXPLANATION}"),
                'score', RECORD_ATTRIBUTES:"${l.ae.EVAL_SCORE}",
                'raw', RECORD_ATTRIBUTES
            )
        ) AS CHILD_ATTRIBUTES
    FROM
        TABLE(snowflake.local.GET_AI_OBSERVABILITY_EVENTS(?, ?, ?, ?))
    JOIN OBJECT_IDS ON TRUE
    WHERE
        RECORD_ATTRIBUTES:"${l.ae.SPAN_TYPE}" = '${l.du.EVAL}' AND
        RECORD_ATTRIBUTES:"${l.ae.RUN_ID}" = OBJECT_IDS.IDS:run.id
    GROUP BY
        ROOT_ID
)
    SELECT
        rs.RECORD_ATTRIBUTES:"${l.ae.EVAL_EVAL_ROOT_ID}" as ID,
        rs.RECORD_ATTRIBUTES:"${l.ae.EVAL_FEEDBACK_NAME}" AS NAME,
        rs.RECORD_ATTRIBUTES:"${l.ae.EVAL_ROOT_SCORE}" AS SCORE,
        rs.RECORD_ATTRIBUTES:"${l.ae.EVAL_ROOT_ERROR}" AS ERROR,
        COALESCE(cs.CHILD_ATTRIBUTES, []) AS CALLS
    FROM EVAL_ROOT_SPANS rs LEFT JOIN EVAL_SPANS cs ON rs.RECORD_ATTRIBUTES:"${l.ae.EVAL_EVAL_ROOT_ID}" = cs.ROOT_ID
        ;`,(0,o.Q)((0,r.S)(n)),(0,o.Q)(d),(0,o.Q)((0,r.S)(e)),(0,o.Q)((0,r.S)(t)),(0,o.Q)(s),(0,o.Q)((0,r.S)(e)),(0,o.Q)((0,r.S)(t)),(0,o.Q)((0,r.S)(n)),(0,o.Q)(d),(0,o.Q)(i),(0,o.Q)((0,r.S)(e)),(0,o.Q)((0,r.S)(t)),(0,o.Q)((0,r.S)(n)),(0,o.Q)(d)),u.toQuery()}},79407(e,t,n){n.d(t,{L:()=>o});var a=n(890935),r=n(379855);let o=async(e,t,n)=>{let o={...t,run:t.run.name,spanType:a.du.EVAL_ROOT,additionalFilters:[`RECORD_ATTRIBUTES:"${a.ae.EVAL_FEEDBACK_NAME}" = '${n}'`]};try{let t=(0,r.J)(e,o),n=(0,r.J)(e,{...o,additionalFilters:[...o.additionalFilters,`RECORD_ATTRIBUTES:"${a.ae.EVAL_ROOT_ERROR}" IS NULL`]}),[l,s]=await Promise.all([t,n]);return{spanCount:l,spanCountWithoutError:s}}catch(e){return{spanCount:-1,spanCountWithoutError:-1}}}},527625(e,t,n){n.d(t,{F:()=>s});var a=n(638225),r=n(861028),o=n(296608),l=n(890935);let s=(e,t,n,s)=>{let i=new a.e;return i.add(`
WITH EVAL_RESULTS AS (
    SELECT 
        RECORD_ATTRIBUTES:"${l.ae.OBJECT_NAME}" AS APP_NAME,
        RECORD_ATTRIBUTES:"${l.ae.OBJECT_VERSION}" AS APP_VERSION,
        RECORD_ATTRIBUTES:"${l.ae.RUN_NAME}" AS RUN_NAME,
        RECORD_ATTRIBUTES:"${l.ae.RECORD_ID}" AS RECORD_ID,
        RECORD_ATTRIBUTES:"${l.ae.EVAL_FEEDBACK_NAME}" AS FEEDBACK_NAME,
        AVG(RECORD_ATTRIBUTES:"${l.ae.EVAL_ROOT_SCORE}") AS AVERAGE_SCORE,
    FROM TABLE(snowflake.local.GET_AI_OBSERVABILITY_EVENTS(?, ?, ?, ?))
    WHERE
        APP_VERSION IS NOT NULL AND 
        RUN_NAME IS NOT NULL AND 
        RECORD_ID IS NOT NULL
    GROUP BY 
        APP_NAME,
        APP_VERSION,
        RUN_NAME,
        RECORD_ID,
        FEEDBACK_NAME
),
AGGREGATED_EVAL_RESULTS AS (
    SELECT 
        APP_NAME,
        APP_VERSION,
        RUN_NAME,
        FEEDBACK_NAME,
        AVG(AVERAGE_SCORE) AS AVERAGE_SCORE_FOR_APP
    FROM EVAL_RESULTS
    GROUP BY APP_NAME, APP_VERSION, RUN_NAME, FEEDBACK_NAME
),
AGGREGATED_EVAL_RESULTS_BY_RUN AS (
    SELECT 
        APP_NAME,
        APP_VERSION,
        RUN_NAME,
        ARRAY_AGG(OBJECT_CONSTRUCT('name', FEEDBACK_NAME, 'result', AVERAGE_SCORE_FOR_APP)) AS METRICS
    FROM 
        AGGREGATED_EVAL_RESULTS 
    GROUP BY APP_NAME, APP_VERSION, RUN_NAME
),
RECORD_COUNTS AS (
    SELECT 
        RECORD_ATTRIBUTES:"${l.ae.OBJECT_NAME}" AS APP_NAME,
        RECORD_ATTRIBUTES:"${l.ae.OBJECT_VERSION}" AS APP_VERSION,
        RECORD_ATTRIBUTES:"${l.ae.RUN_NAME}" AS RUN_NAME,
        COUNT(*) AS COUNT
    FROM
        TABLE(snowflake.local.GET_AI_OBSERVABILITY_EVENTS(?, ?, ?, ?))
    WHERE
        APP_NAME IS NOT NULL AND 
        APP_VERSION IS NOT NULL AND 
        RUN_NAME IS NOT NULL AND 
        RECORD_ATTRIBUTES:"${l.ae.SPAN_TYPE}" = '${l.du.RECORD_ROOT}'
    GROUP BY
        APP_NAME, APP_VERSION, RUN_NAME
)
SELECT 
    AER.APP_NAME,
    AER.APP_VERSION,
    AER.RUN_NAME,
    RC.COUNT AS NUM_RECORDS,
    AER.METRICS,
FROM 
    AGGREGATED_EVAL_RESULTS_BY_RUN AER 
        LEFT JOIN 
