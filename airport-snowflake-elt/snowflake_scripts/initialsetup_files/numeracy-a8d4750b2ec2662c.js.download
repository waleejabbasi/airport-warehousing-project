      privacy_category_columns as (
          select tag_name,tag_value,column_id,column_name from table_tag_reference where tag_name = 'PRIVACY_CATEGORY' and TAG_VALUE = 'IDENTIFIER'
      ),
      semantic_category as (
          select tag_name,tag_value,column_id,column_name from table_tag_reference where tag_name = 'SEMANTIC_CATEGORY'
      ),
      sensitive_columns as (
          select semantic_category.tag_value,semantic_category.column_name,semantic_category.column_id from semantic_category inner join privacy_category_columns on semantic_category.column_id = privacy_category_columns.column_id
      ),
      classification_section as ( select * from snowflake.account_usage.data_classification_latest ),
      classification_section_detail as (
